page {
  background-color: #F7F8FA;
}
.container { padding: 20rpx; }

.header-bar { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 10rpx; margin-bottom: 10rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #333; }
.clear-btn { font-size: 26rpx; color: #999; }

.history-item { 
  background: #fff; 
  padding: 30rpx; 
  border-radius: 16rpx; 
  margin-bottom: 24rpx; 
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.row-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.symbol { font-size: 32rpx; font-weight: bold; color: #333; margin-right: 12rpx; }
.name { font-size: 24rpx; color: #999; }
.price { font-size: 32rpx; font-weight: bold; color: #F54336; }

.row-bottom { margin-bottom: 20rpx; }
.time { font-size: 22rpx; color: #ccc; }

/* 修复建议框的文字颜色 */
.advice-box {
  background: #F9F9F9;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333; /* ✅ 强制深色文字，防止隐身 */
  line-height: 1.6;
}

.empty-tip { text-align: center; margin-top: 200rpx; color: #ccc; font-size: 26rpx; }