<view class="container">
  <view class="header-status">
    <view class="circle-box">
      <view class="circle-ring">
        <text class="percent">100<text class="symbol">%</text></text>
      </view>
    </view>
    <view class="status-text">风险测评由 AlphaMind 提供</view>
    <view class="status-sub">请确认以下信息（点击即可修改）提交后完成风测</view>
  </view>

  <view class="info-list card">
    <view class="info-item" wx:for="{{displayList}}" wx:key="field" bindtap="onModify" data-idx="{{index}}">
      <view class="item-main">
        <view class="item-title">{{item.title}}</view>
        <view class="item-value">{{item.label || '未选择'}}</view>
      </view>
      <view class="item-action">
        <text>修改</text>
        <text class="arrow">></text>
      </view>
    </view>
  </view>

  <view class="footer-area">
    <view class="btn-submit" bindtap="onSubmit">确认无误，提交</view>
  </view>
</view>