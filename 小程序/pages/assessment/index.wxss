page {
  background-color: #F5F7FA;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0;
}

/* 进度条区域 */
.header-progress {
  padding: 30rpx 40rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.progress-bg {
  flex: 1;
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 20rpx;
}
.progress-bar {
  height: 100%;
  background: #1677FF; /* 支付宝蓝 */
  transition: width 0.3s ease;
  border-radius: 6rpx;
}
.progress-text {
  font-size: 28rpx;
  font-family: 'DIN Alternate', sans-serif;
}
.current { color: #1677FF; font-weight: bold; font-size: 36rpx; }
.total { color: #999; }

/* Swiper 容器 */
.question-swiper {
  flex: 1; /* 撑满剩余空间 */
}

/* 问题卡片 */
.question-card {
  margin: 30rpx 40rpx;
  /* 不设背景色，让选项看起来是悬浮的，或者设为白色卡片 */
}

.q-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 60rpx;
  line-height: 1.4;
}

/* 选项列表 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  background: #fff;
  padding: 32rpx 40rpx;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.2s;
}

.option-item:active {
  transform: scale(0.98);
  background: #F5F9FF;
}

/* 选中状态 */
.option-item.selected {
  border-color: #1677FF;
  background: #E6F4FF;
  color: #1677FF;
  font-weight: 500;
}

.opt-label { font-size: 30rpx; }
.opt-check { font-weight: bold; font-size: 32rpx; }

/* 输入框样式 */
.input-box {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
}
.q-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 30rpx;
  color: #333;
}
.btn-next {
  margin-top: 30rpx;
  background: #1677FF;
  color: #fff;
  border-radius: 40rpx;
}

/* 底部导航优化 */
.footer-nav {
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between; /* 两端对齐 */
}

.nav-btn {
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-weight: bold;
  transition: all 0.3s;
}

.nav-btn.prev {
  background: #F5F7FA;
  color: #666;
}
.nav-btn.prev.disabled {
  opacity: 0; /* 第一题隐藏上一题按钮 */
  pointer-events: none;
}

.nav-btn.next {
  background: #E6F4FF;
  color: #1677FF;
}
.nav-btn.next:active {
  background: #d0eaff;
}