page { background-color: #0A1E36; color: #fff; }
.container { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; }
.logo { width: 160rpx; height: 160rpx; margin-bottom: 40rpx; }
.title { font-size: 60rpx; font-weight: bold; letter-spacing: 4rpx; margin-bottom: 20rpx; }
.subtitle { font-size: 28rpx; opacity: 0.8; letter-spacing: 2rpx; margin-bottom: 120rpx; }
.btn-start { 
  background: #0052D4; color: #fff; 
  padding: 24rpx 80rpx; border-radius: 50rpx; 
  font-size: 32rpx; font-weight: bold; 
  box-shadow: 0 4rpx 20rpx rgba(0, 82, 212, 0.4);
}
.btn-start:active { transform: scale(0.95); opacity: 0.9; }
.loading-text { font-size: 24rpx; opacity: 0.6; }