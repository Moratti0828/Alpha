/* 全局修正 */
.text-up { color: #F54336 !important; }
.text-down { color: #00C853 !important; }
.bg-up { background-color: #F54336; }
.bg-down { background-color: #00C853; }

/* 热门标的 - 小卡片风格 */
.hot-tags { display: flex; flex-wrap: wrap; justify-content: space-between; padding: 0 10rpx; }
.tag-card {
  width: 30%; background: #fff; border-radius: 12rpx; padding: 20rpx;
  margin-bottom: 20rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
  box-sizing: border-box; border: 1rpx solid #f0f0f0;
}
.tag-top { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.tag-name { font-size: 26rpx; font-weight: bold; color: #333; }
.tag-symbol { font-size: 22rpx; color: #999; font-family: 'DIN Alternate', sans-serif; }

/* 最近访问列表 */
.recent-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 30rpx; margin-bottom: 20rpx; background: #fff;
  border-radius: 12rpx; border-left: 6rpx solid #1677FF;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.recent-left .name { font-size: 30rpx; font-weight: bold; color: #333; display: block; }
.recent-left .symbol { font-size: 24rpx; color: #999; }
.recent-right .price { font-weight: bold; color: #333; font-size: 32rpx; margin-right: 10rpx; }
.recent-right .arrow { color: #ccc; font-size: 24rpx; }

/* 操作按钮 (历史/主页) */
.quick-actions { display: flex; justify-content: flex-end; margin-bottom: 24rpx; padding: 0 10rpx; }
.action-btn {
  display: flex; align-items: center; font-size: 26rpx;
  color: #333; /* 黑色文字 */
  background: #EAEAEA; /* 浅灰背景 */
  padding: 12rpx 28rpx; border-radius: 30rpx; font-weight: 500;
  margin-left: 20rpx;
}
.action-btn .icon { margin-right: 8rpx; }

/* 图表切换 */
.chart-switch { display: flex; background: #F0F2F5; border-radius: 16rpx; padding: 8rpx; margin-bottom: 20rpx; }
.switch-item { flex: 1; text-align: center; font-size: 26rpx; color: #666; padding: 14rpx 0; border-radius: 12rpx; }
.switch-item.active { background: #fff; color: #000; font-weight: bold; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05); }

/* 股票详情卡片 */
.info-card { background: #fff !important; padding: 40rpx 30rpx; min-height: auto; }
.info-card .symbol { font-size: 44rpx; font-weight: 900; color: #1A1A1A; }
.info-card .name { font-size: 26rpx; color: #666; margin-top: 4rpx; }
.info-card .price { font-size: 80rpx; font-weight: bold; margin-right: 30rpx; line-height: 1; font-family: 'DIN Alternate', sans-serif; }

/* 图表容器 */
.chart-container { height: 500rpx; background: #fff; border-radius: 16rpx; padding: 10rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03); }
ec-canvas { width: 100%; height: 100%; }

/* AI 建议 */
.llm-card { background: #fff; padding: 30rpx; margin-bottom: 120rpx; border-radius: 16rpx; }
.llm-header { display: flex; align-items: center; margin-bottom: 20rpx; border-bottom: 1px solid #eee; padding-bottom: 16rpx; }
.llm-header .title { font-weight: bold; color: #1677FF; font-size: 30rpx; }
.llm-rich-text { font-size: 30rpx; line-height: 1.7; color: #333; }

/* === AI 思考动画样式 === */
.thinking-box {
  margin-top: 60rpx;
  padding: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  animation: fadeIn 0.5s;
}

.think-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
}

.spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #E6F4FF;
  border-top-color: #1677FF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 20rpx;
}

.think-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1677FF;
  letter-spacing: 2rpx;
}

.think-steps {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.step-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #ccc; /* 默认灰色 */
  transition: all 0.5s ease;
  transform: translateX(0);
}

.step-item.active {
  color: #333; /* 激活变黑 */
  font-weight: 500;
  transform: translateX(10rpx); /* 轻微位移 */
}

.step-item .icon {
  margin-right: 20rpx;
  font-size: 32rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}