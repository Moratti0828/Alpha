/* ... 保留原有的 page, header-bg, card 样式 ... */

/* 用户信息卡片 */
.user-info-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
  position: relative;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  display: block;
}

.nickname-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: bold;
  color: #333; /* 强制深色字体 */
  flex: 1;
  padding: 0;
  margin: 0;
  border: none;
  outline: none;
  background: transparent;
}

.edit-icon {
  font-size: 30rpx;
  color: #999;
  margin-left: 10rpx;
}

.badge {
  display: inline-block;
  background-color: #e0f2fe;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  border: 1px solid #7dd3fc;
}

.badge text {
  font-size: 24rpx;
  color: #0284c7;
}

/* 策略报告卡片 */
.assessment-card {
  margin: 0 24rpx 24rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.status-tag {
  font-size: 20rpx;
  background-color: #e0f2fe;
  color: #0284c7;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  border: 1px solid #7dd3fc;
}

.ai-summary {
  background-color: #f0f2f5;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.highlight {
  color: #1677FF;
  font-weight: bold;
}

/* 雷达图入口卡片 */
.radar-entry-box {
  margin-top: 30rpx;
  background: linear-gradient(90deg, #F0F7FF 0%, #F5F9FF 100%);
  border: 1rpx solid #E1EAF5;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.3s;
}

.radar-entry-box:active { transform: scale(0.98); background: #E6F0FF; }

.radar-entry-box .left { display: flex; align-items: center; }

.icon-radar { font-size: 40rpx; margin-right: 20rpx; }

.entry-text .main { font-size: 28rpx; font-weight: bold; color: #1677FF; }

.entry-text .sub { font-size: 22rpx; color: #8FA0B5; margin-top: 4rpx; }

.arrow-btn {
  font-size: 24rpx; color: #1677FF; font-weight: bold;
  background: #fff; padding: 8rpx 20rpx; border-radius: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(22,119,255,0.1);
}

/* 底部悬浮操作栏 */
.footer-action-bar {
  position: fixed; bottom: 40rpx; left: 30rpx; right: 30rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1);
  display: flex; overflow: hidden;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

.action-item {
  flex: 1; display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: bold; transition: all 0.3s;
}

.action-item .icon { margin-right: 8rpx; font-size: 32rpx; }

.action-item.secondary {
  background: #fff; color: #333;
}

.action-item.secondary:active { background: #f5f5f5; }

.action-item.primary {
  background: #1677FF; color: #fff;
}

.action-item.primary:active { opacity: 0.9; }

/* 弹窗式表单 */
.form-container {
  position: fixed; bottom: 0; left: 0; width: 100%;
  background: #fff;
  border-top-left-radius: 30rpx; border-top-right-radius: 30rpx;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
  transform: translateY(120%); /* 默认隐藏 */
  transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  z-index: 200;
  max-height: 80vh; overflow-y: auto;
}

.form-container.show { transform: translateY(0); }

.form-header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }

.f-title { font-size: 32rpx; font-weight: bold; color: #333; }

.f-close { font-size: 28rpx; color: #999; padding: 10rpx; }

/* 表单网格布局 */
.form-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.form-item {
  width: 48%; /* 两列布局 */
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
}

.full-width {
  width: 100%;
}

.label {
  font-size: 26rpx;
  color: #666; /* 标签颜色 */
  margin-bottom: 12rpx;
  display: block;
}

.input {
  height: 80rpx;
  line-height: 80rpx;
  border-bottom: 1px solid #eee; /* 底部线条 */
  font-size: 28rpx;
  color: #333; /* 输入文字颜色 */
  padding: 0;
  margin: 0;
  border: none;
  outline: none;
  background: transparent;
}

.placeholder-style {
  color: #ccc; /* 占位符颜色 */
}

.save-btn-inner {
  margin-top: 40rpx;
  background: #1677FF;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 20rpx;
  width: 100%;
  margin-left: auto;
  margin-right: auto;
  border: none;
  outline: none;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.2);
}

/* 修复微信小程序button默认样式 */
button {
  padding: 0;
  margin: 0;
  border: none;
  outline: none;
  background: transparent;
}

button::after {
  border: none;
}