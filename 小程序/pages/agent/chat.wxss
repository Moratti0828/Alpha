.header-card {
    display: flex; justify-content: space-between; align-items: center;
    border-left: 8rpx solid var(--color-primary);
  }
  .name { font-size: 36rpx; font-weight: bold; margin-right: 10rpx; }
  .code { color: #666; }
  .status-badge { font-size: 24rpx; color: var(--color-primary); display: flex; align-items: center; }
  .dot { width: 12rpx; height: 12rpx; background: var(--color-primary); border-radius: 50%; margin-right: 8rpx; animation: pulse 1s infinite; }
  
  /* 思考动画区 */
  .thinking-box {
    padding: 40rpx; margin-top: 40rpx;
  }
  .think-step {
    font-size: 28rpx; color: #999; margin-bottom: 20rpx; opacity: 0.3; transition: all 0.5s;
  }
  .think-step.active {
    opacity: 1; color: #333; font-weight: bold; transform: translateX(10rpx);
  }
  .loading-spinner {
    width: 40rpx; height: 40rpx; border: 4rpx solid #ddd; border-top-color: var(--color-primary);
    border-radius: 50%; animation: spin 1s linear infinite; margin: 40rpx auto;
  }
  
  /* 结果区 */
  .chat-content {
    min-height: 400rpx; background: #fff; font-size: 30rpx; line-height: 1.6; color: #333;
  }
  .markdown-text { white-space: pre-wrap; } /* 保留换行 */
  
  /* 底部栏 */
  .input-bar {
    position: fixed; bottom: 0; left: 0; width: 100%;
    background: #fff; padding: 20rpx; display: flex; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  }
  .chat-input { background: #f5f5f5; padding: 10rpx 20rpx; border-radius: 30rpx; flex: 1; margin-right: 20rpx; }
  .send-btn { color: var(--color-primary); font-weight: bold; padding-top: 10rpx; }
  
  @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } }
  @keyframes spin { to { transform: rotate(360deg); } }